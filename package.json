{
  "name": "onigiribot",
  "version": "1.0.0",
  "description": "An open source, lightweight, do-it-all Discord bot with a web UI!",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "npm run build && npm start",
    "deploy": "ts-node scripts/deploy-commands.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeke-code/OnigiriBot.git"
  },
  "author": "zeke-code",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/zeke-code/OnigiriBot/issues"
  },
  "homepage": "https://github.com/zeke-code/OnigiriBot#readme",
  "dependencies": {
    "@discord-player/extractor": "^7.1.0",
    "@discordjs/voice": "^0.18.0",
    "@prisma/client": "^6.10.1",
    "axios": "^1.8.4",
    "bgutils-js": "^3.2.0",
    "discord-player": "^7.1.0",
    "discord-player-youtubei": "^1.4.5",
    "discord.js": "^14.18.0",
    "dotenv": "^17.0.0",
    "ffmpeg-static": "^5.2.0",
    "mongoose": "^8.13.2",
    "redis": "^5.5.6",
    "winston": "^3.17.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.10.1"
  }
}
